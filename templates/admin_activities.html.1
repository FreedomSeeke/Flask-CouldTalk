<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>用户行为日志</title>
    <link rel="icon" href="{{ url_for('static', filename='images/heart.ico') }}" type="image/x-icon">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #f5f5f5;
            font-family: "Microsoft YaHei", sans-serif;
            padding: 20px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e0e0e0;
        }
        .header h1 {
            color: #333;
        }
        .nav-links {
            display: flex;
            gap: 10px;
        }
        .nav-link {
            color: #1677ff;
            text-decoration: none;
            padding: 5px 10px;
            border: 1px solid #1677ff;
            border-radius: 5px;
        }
        .logout-link {
            color: #ff3b30;
            text-decoration: none;
            padding: 5px 10px;
            border: 1px solid #ff3b30;
            border-radius: 5px;
        }
        .action-buttons {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
        }
        .btn-danger {
            background: #ff4d4f;
            color: white;
        }
        .btn-danger:hover {
            background: #ff7875;
        }
        .btn-warning {
            background: #faad14;
            color: white;
        }
        .btn-warning:hover {
            background: #ffc53d;
        }
        .activity-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        .activity-table th, .activity-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #e0e0e0;
        }
        .activity-table th {
            background: #f9f9f9;
            color: #333;
        }
        .checkbox-column {
            width: 40px;
        }
        .action-column {
            width: 100px;
        }
        .action-tag {
            padding: 3px 8px;
            border-radius: 5px;
            font-size: 12px;
        }
        .tag-login {
            background: #e6f7ef;
            color: #07C160;
        }
        .tag-logout {
            background: #f5f5f5;
            color: #999;
        }
        .tag-message {
            background: #e6f7ff;
            color: #1890ff;
        }
        .tag-file {
            background: #f6ffed;
            color: #52c41a;
        }
        .tag-admin {
            background: #fff7e6;
            color: #fa8c16;
        }
        .tag-access {
            background: #fff1f0;
            color: #ff4d4f;
        }
        .ip-address {
            font-family: monospace;
            font-size: 12px;
        }
        .activity-detail {
            font-size: 12px;
            color: #666;
        }
        .delete-btn {
            color: #ff4d4f;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 3px;
        }
        .delete-btn:hover {
            background: #fff1f0;
        }
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.4);
        }
        .modal-content {
            background-color: #fefefe;
            margin: 15% auto;
            padding: 20px;
            border: 1px solid #888;
            width: 300px;
            border-radius: 10px;
            text-align: center;
        }
        .modal-buttons {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 20px;
        }
        .success-message {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #52c41a;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            z-index: 1000;
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>用户行为日志</h1>
        <div class="nav-links">
            <a href="/admin/panel" class="nav-link">返回管理员面板</a>
            <a href="/logout" class="logout-link">退出登录</a>
        </div>
    </div>

    <div class="action-buttons">
        <button id="batchDeleteBtn" class="btn btn-danger" disabled>批量删除</button>
        <button id="clearAllBtn" class="btn btn-warning">清空所有</button>
    </div>

    <table class="activity-table">
        <thead>
            <tr>
                <th class="checkbox-column">
                    <input type="checkbox" id="selectAll">
                </th>
                <th>ID</th>
                <th>用户名</th>
                <th>IP地址</th>
                <th>行为类型</th>
                <th>行为详情</th>
                <th>发生时间</th>
                <th class="action-column">操作</th>
            </tr>
        </thead>
        <tbody>
            {% for activity in activities %}
            <tr>
                <td>
                    <input type="checkbox" class="activity-checkbox" value="{{ activity.id }}">
                </td>
                <td>{{ activity.id }}</td>
                <td>{{ activity.username }}</td>
                <td class="ip-address">{{ activity.ip_address }}</td>
                <td>
                    {% if activity.action_type == 'login' %}
                        <span class="action-tag tag-login">登录</span>
                    {% elif activity.action_type == 'logout' %}
                        <span class="action-tag tag-logout">登出</span>
                    {% elif activity.action_type == 'send_message' %}
                        <span class="action-tag tag-message">发送消息</span>
                    {% elif activity.action_type == 'send_file' %}
                        <span class="action-tag tag-file">发送文件</span>
                    {% elif activity.action_type == 'upload_file' %}
                        <span class="action-tag tag-file">上传文件</span>
                    {% elif activity.action_type == 'admin_action' %}
                        <span class="action-tag tag-admin">管理员操作</span>
                    {% elif activity.action_type == 'admin_access' %}
                        <span class="action-tag tag-access">后台访问</span>
                    {% else %}
                        <span class="action-tag tag-logout">{{ activity.action_type }}</span>
                    {% endif %}
                </td>
                <td class="activity-detail">{{ activity.action_detail or '无' }}</td>
                <td>{{ activity.created_at }}</td>
                <td>
                    <button class="delete-btn" data-id="{{ activity.id }}">删除</button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- 删除确认弹窗 -->
    <div id="deleteModal" class="modal">
        <div class="modal-content">
            <p id="modalMessage">确定要删除所选日志吗？</p>
            <div class="modal-buttons">
                <button id="cancelBtn" class="btn">取消</button>
                <button id="confirmBtn" class="btn btn-danger">确定</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.bootcdn.net/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        $(document).ready(function() {
            // 全选/取消全选
            $('#selectAll').change(function() {
                $('.activity-checkbox').prop('checked', $(this).prop('checked'));
                updateBatchDeleteBtn();
            });

            // 单个复选框变化
            $('.activity-checkbox').change(function() {
                updateBatchDeleteBtn();
            });

            // 更新批量删除按钮状态
            function updateBatchDeleteBtn() {
                var checkedCount = $('.activity-checkbox:checked').length;
                $('#batchDeleteBtn').prop('disabled', checkedCount === 0);
            }

            // 单个删除
            $('.delete-btn').click(function() {
                var activityId = $(this).data('id');
                $('#modalMessage').text('确定要删除这条日志吗？');
                $('#deleteModal').data('action', 'single').data('id', activityId).show();
            });

            // 批量删除
            $('#batchDeleteBtn').click(function() {
                var checkedIds = $('.activity-checkbox:checked').map(function() {
                    return $(this).val();
                }).get();
                $('#modalMessage').text('确定要删除所选的 ' + checkedIds.length + ' 条日志吗？');
                $('#deleteModal').data('action', 'batch').data('ids', checkedIds).show();
            });

            // 清空所有
            $('#clearAllBtn').click(function() {
                $('#modalMessage').text('确定要清空所有日志吗？此操作不可恢复！');
                $('#deleteModal').data('action', 'clear').show();
            });

            // 取消删除
            $('#cancelBtn').click(function() {
                $('#deleteModal').hide();
            });

            // 确认删除
            $('#confirmBtn').click(function() {
                var action = $('#deleteModal').data('action');
                var url, data;

                if (action === 'single') {
                    var id = $('#deleteModal').data('id');
                    url = '/admin/delete_activity/' + id;
                    data = {};
                } else if (action === 'batch') {
                    var ids = $('#deleteModal').data('ids');
                    url = '/admin/delete_activities';
                    data = { ids: ids };
                } else if (action === 'clear') {
                    url = '/admin/clear_activities';
                    data = {};
                }

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: JSON.stringify(data),
                    contentType: 'application/json',
                    success: function(response) {
                        if (response.code === 1) {
                            showSuccessMessage(response.msg);
                            setTimeout(function() {
                                location.reload();
                            }, 1000);
                        } else {
                            alert(response.msg);
                        }
                    },
                    error: function() {
                        alert('删除失败，请重试');
                    }
                });

                $('#deleteModal').hide();
            });

            // 显示成功消息
            function showSuccessMessage(msg) {
                var $message = $('<div class="success-message">' + msg + '</div>');
                $('body').append($message);
                setTimeout(function() {
                    $message.fadeOut(500, function() {
                        $(this).remove();
                    });
                }, 2000);
            }

            // 点击弹窗外部关闭
            $(window).click(function(event) {
                if (event.target.id === 'deleteModal') {
                    $('#deleteModal').hide();
                }
            });
        });
    </script>
</body>
</html>